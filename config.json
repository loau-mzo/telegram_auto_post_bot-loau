  "database_schema": {
    "tables": [
      {
        "name": "users",
        "columns": [
          {
            "name": "user_id",
            "type": "INTEGER PRIMARY KEY"
          },
          {
            "name": "username",
            "type": "TEXT"
          },
          {
            "name": "first_name",
            "type": "TEXT"
          },
          {
            "name": "last_name",
            "type": "TEXT"
          },
          {
            "name": "is_approved",
            "type": "BOOLEAN DEFAULT FALSE"
          },
          {
            "name": "approval_date",
            "type": "TIMESTAMP"
          },
          {
            "name": "created_date",
            "type": "TIMESTAMP DEFAULT CURRENT_TIMESTAMP"
          }
        ]
      },
      {
        "name": "channels",
        "columns": [
          {
            "name": "channel_id",
            "type": "TEXT PRIMARY KEY"
          },
          {
            "name": "channel_username",
            "type": "TEXT"
          },
          {
            "name": "owner_id",
            "type": "INTEGER"
          },
          {
            "name": "content_type",
            "type": "TEXT"
          },
          {
            "name": "posting_schedule",
            "type": "TEXT"
          },
          {
            "name": "custom_signature",
            "type": "TEXT"
          },
          {
            "name": "sources_mention",
            "type": "BOOLEAN DEFAULT TRUE"
          },
          {
            "name": "active",
            "type": "BOOLEAN DEFAULT TRUE"
          },
          {
            "name": "created_date",
            "type": "TIMESTAMP DEFAULT CURRENT_TIMESTAMP"
          },
          {
            "name": "FOREIGN KEY (owner_id)",
            "references": "users (user_id)"
          }
        ]
      },
      {
        "name": "approval_requests",
        "columns": [
          {
            "name": "request_id",
            "type": "INTEGER PRIMARY KEY AUTOINCREMENT"
          },
          {
            "name": "user_id",
            "type": "INTEGER"
          },
          {
            "name": "request_date",
            "type": "TIMESTAMP DEFAULT CURRENT_TIMESTAMP"
          },
          {
            "name": "status",
            "type": "TEXT DEFAULT 'pending'"
          },
          {
            "name": "response_date",
            "type": "TIMESTAMP"
          },
          {
            "name": "FOREIGN KEY (user_id)",
            "references": "users (user_id)"
          }
        ]
      },
      {
        "name": "published_content",
        "columns": [
          {
            "name": "content_id",
            "type": "INTEGER PRIMARY KEY AUTOINCREMENT"
          },
          {
            "name": "channel_id",
            "type": "TEXT"
          },
          {
            "name": "content_text",
            "type": "TEXT"
          },
          {
            "name": "content_image",
            "type": "BLOB"
          },
          {
            "name": "signature",
            "type": "TEXT"
          },
          {
            "name": "post_date",
            "type": "TIMESTAMP"
          },
          {
            "name": "created_date",
            "type": "TIMESTAMP DEFAULT CURRENT_TIMESTAMP"
          },
          {
            "name": "FOREIGN KEY (channel_id)",
            "references": "channels (channel_id)"
          }
        ]
      }
    ]
  },
